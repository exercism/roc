#!/usr/bin/env bash

# Synopsis:
# Install Roc

function download_alpha_release() {
    local install_dir="${1}"
    rm -rf "${install_dir}"
    mkdir -p "${install_dir}"
    cd "${install_dir}"
    wget --secure-protocol=TLSv1_2 -qO- https://roc-lang.org/install_roc.sh | ROC_CONTINUE_IF_STALE=y ROC_ADD_TO_PATH=n sh
    ln -s roc_nightly*/roc roc
}

function update_shell {
    local install_dir="${1}"
    local file="${HOME}/${2}"

    if [[ -f "${file}" ]]; then
        echo "export PATH=${install_dir}:\$PATH" >> "${file}"
        source "${file}"
    fi
}

install_dir="${HOME}/.roc/bin"

download_alpha_release "${install_dir}"

if [[ -z "${GITHUB_ACTIONS}" ]]; then
    update_shell "${install_dir}" ".bashrc" 
    update_shell "${install_dir}" ".zshrc"
else
    echo "${install_dir}" >> "${GITHUB_PATH}"
fi
