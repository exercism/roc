# The following function should soon be available in Roc's builtins
is_approx_eq : Dec, Dec, { atol: Dec } -> Bool
is_approx_eq = |x, y, {atol}| {
	to_int : Dec -> Try(I64, [OutOfRange])
	to_int = |f| {
		(f / atol + 0.5).to_i64_try()
	}

	match (to_int(x), to_int(y)) {
		(Ok(xi), Ok(yi)) => (xi == yi)
		_ => Bool.False
	}
}

