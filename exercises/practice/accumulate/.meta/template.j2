to_upper_char : U8 -> U8
to_upper_char = |byte| {
	if 'a' <= byte and byte <= 'z' {
		byte - 'a' + 'A'
	} else {
		byte
	}
}

to_upper : Str -> Str
to_upper = |str| {
	str.to_utf8().map(to_upper_char)->Str.from_utf8() ?? ""
}

str_reverse : Str -> Str
str_reverse = |str| {
	str
		.to_utf8()
		->reverse()
		->Str.from_utf8()
		?? ""
}

# List.reverse should soon be available in Roc's builtins
reverse : List(a) -> List(a)
reverse = |list| {
	match list {
		[] => []
		[first, .. as rest] => reverse(rest).append(first)
	}
}

