{{ macros.canonical_ref() }}
{{ macros.header() }}

import {{ exercise | to_pascal }}

{% set accumulators = {
    "(x) => x * x": "|x| { x * x }",
    "(x) => upcase(x)": "to_upper",
    "(x) => reverse(x)": "reverse",
    "(x) => accumulate([\"1\", \"2\", \"3\"], (y) => x + y)": "|x| {\n        Accumulate.accumulate([\"1\", \"2\", \"3\"], |y| { Str.concat(x, y) })\n    }"
} -%}

{% for case in cases -%}
# {{ case["description"] }}
expect {
    result = {{ exercise | to_pascal }}.{{ case["property"] | to_snake }}({{ case["input"]["list"] | to_roc }}, {{ accumulators[case["input"]["accumulator"]] }})
    result == {{ case["expected"] | to_roc }}
}

{% endfor -%}

reverse_list : List(a) -> List(a)
reverse_list = |list| {
    match list {
        [] => []
        [first, .. as rest] => reverse_list(rest).append(first)
    }
}

reverse : Str -> Str
reverse = |str| {
    str
    .to_utf8()
    ->reverse_list
    ->Str.from_utf8
    ?? ""
}

to_upper_char : U8 -> U8
to_upper_char = |byte| {
    if 'a' <= byte and byte <= 'z' {
        byte - 'a' + 'A'
    } else {
        byte
    }
}

to_upper : Str -> Str
to_upper = |str| {
    str.to_utf8().map(to_upper_char)->Str.from_utf8 ?? ""
}
