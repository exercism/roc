{%- import "generator_macros.j2" as macros with context -%}
{{ macros.canonical_ref() }}
{{ macros.header() }}

import {{ exercise | to_pascal }}

{% for case in cases -%}
# {{ case["description"] }}
expect {
    rolls = {{ case["input"]["previousRolls"] | to_roc }}
    game = game_with_previous_rolls(rolls)?
    {%- if case["property"] == "score" %}
    result = game.score()
    {%- else %}
    result = game.{{ case["property"] | to_snake }}({{ case["input"]["roll"] }})
    {%- endif %}
    {%- if case["expected"]["error"] %}
    result.is_err()
    {%- else %}
    result == Ok({{ case["expected"] | to_roc }})
    {%- endif %}
}
    {%- if case["property"] == "score" and not case["expected"]["error"] %}

# should be able to replay this finished game from the start
expect {
    rolls = {{ case["input"]["previousRolls"] | to_roc }}
    result = game_with_previous_rolls(rolls)
    result.is_ok()
}

    {%- endif %}


{% endfor %}

game_with_previous_rolls : List(U64) -> Try(Bowling, _)
game_with_previous_rolls = |rolls| {
    var $game = Bowling.new
    for pins in rolls {
        $game = $game.roll(pins)?
    }
    Ok($game)
}

{{ macros.footer() }}
